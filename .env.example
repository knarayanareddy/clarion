# Slack (get from your app in Slack Dev Program sandbox: Basic Info / OAuth & Permissions)
# Required for bot to run
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # App-Level Token with connections:write

# Optional for full features (F3, F6+)
# Create a user token (xoxp-) via OAuth flow in sandbox for demo users or use bot for non-RTS
SLACK_USER_TOKEN=xoxp-...

# OpenAI (required for LLM / vision features)
OPENAI_API_KEY=sk-...

# Optional: OpenAI model override
OPENAI_MODEL=gpt-4o

# DB path (defaults to ./clarion.db)
DB_PATH=./clarion.db
